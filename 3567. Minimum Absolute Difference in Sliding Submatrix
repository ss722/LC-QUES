class Solution {
public:
    vector<vector<int>> minAbsDiff(vector<vector<int>>& grid, int k) {
        int n=grid.size();
        int m=grid[0].size();
        if(k>n || k>m) return {};
        vector<vector<int>> ans(n-k+1,vector<int>(m-k+1,0));

        for(int i=0;i<n-k+1;i++){
            for(int j=0;j<m-k+1;j++){
                vector<int> v;
                // cout<<"For i "<<i<<" For j "<<j<<endl;
                for(int ii=i;ii<i+k;ii++){
                    for(int jj=j;jj<j+k;jj++){
                        // cout<<grid[ii][jj]<<" ";
                        v.push_back(grid[ii][jj]);
                    }
                    // cout<<endl;
                }
                sort(begin(v),end(v));
                int mini = INT_MAX;
                for(int ind =1;ind<v.size();ind++){
                    if(v[ind]==v[ind-1]) continue;
                    mini = min(mini,abs(v[ind]-v[ind-1]));
                }
                mini = mini==INT_MAX ? 0 : mini;
                ans[i][j] = mini;
            }
        }
        return ans;
    }
};
